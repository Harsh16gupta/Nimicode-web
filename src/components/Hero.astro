---
import InstallCommand from './InstallCommand.tsx';
import TerminalDemo from './TerminalDemo.tsx';
import { ArrowRight, Github, Terminal } from 'lucide-react';
---

<section class="relative w-full max-w-[1280px] mx-auto px-5 sm:px-8 pt-[clamp(96px,12vw,144px)] pb-16 md:pb-24">
  <div class="grid md:grid-cols-[560px_1fr] gap-12 lg:gap-16 items-center">
    
    <!-- Left Column: Copy & Actions (CSS Animated) -->
    <div class="flex flex-col max-w-[560px]">
      
      <!-- Heading -->
      <h1 class="animate-fade-up font-heading font-semibold text-text leading-[1.08] tracking-[-0.02em] mb-5 opacity-0 select-text" style="font-size: clamp(2rem, 4.8vw, 3.5rem); animation-fill-mode: forwards;">
        The Lightest, Most <span class="text-accent">Steerable</span> AI Coding Agent in Your Terminal.
      </h1>
      
      <!-- Subtext -->
      <p class="animate-fade-up font-body font-normal text-text-muted leading-[1.65] mb-8 opacity-0 [animation-delay:150ms] select-text" style="font-size: clamp(0.95rem, 2.2vw, 1.125rem); max-width: 520px; animation-fill-mode: forwards;">
        Stop wasting tokens on bloated context. Nimicode uses a dual-loop Planner-Executor architecture to solve complex tasks with 90% lower API bills. Beautiful TUI. Completely local. Aggressively steerable.
      </p>
      
      <!-- CTA buttons row -->
      <div class="animate-fade-up opacity-0 [animation-delay:300ms]" style="animation-fill-mode: forwards;">
        <div class="flex flex-wrap items-center gap-3">
          <!-- Primary CTA Button -->
          <a 
            href="#install" 
            class="bg-text text-bg rounded-lg px-6 py-3 font-sans font-semibold text-sm flex items-center justify-center gap-2 transition-all duration-150 hover:bg-text/90 active:scale-[0.97] group"
          >
            <span>Get Started</span>
            <ArrowRight size={16} className="transition-transform duration-150 group-hover:translate-x-0.5" />
          </a>
          
          <!-- Secondary CTA Button -->
          <a 
            href="https://github.com/Harsh16gupta/Nimicode-web"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-transparent border border-border text-text rounded-lg px-6 py-3 font-sans font-semibold text-sm flex items-center justify-center gap-2 transition-all duration-150 hover:bg-white/5 hover:border-text-muted active:scale-[0.97]"
          >
            <Github size={16} />
            <span>View on GitHub</span>
          </a>
        </div>

        {/* Copy-pasteable Command component React Island */}
        <div class="flex flex-col items-start mt-2" id="install">
          <InstallCommand client:load />
        </div>
      </div>

    </div>

    <!-- Right Column: Interactive Terminal Simulator React Island -->
    <div class="w-full flex items-center justify-center md:justify-start">
      <TerminalDemo client:visible />
    </div>

  </div>
</section>
