---
import MobileMenu from './MobileMenu.tsx';
import { Star, Terminal } from 'lucide-react';

const links = [
  { name: 'Docs', href: 'https://github.com/Harsh16gupta/Nimicode-web#readme' },
  { name: 'Tools', href: '/tools' },
  { name: 'Providers', href: '/providers' },
  { name: 'GitHub', href: 'https://github.com/Harsh16gupta/Nimicode-web' },
  { name: 'Roadmap', href: '/roadmap' }
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-350 w-full bg-bg/50 border-b border-transparent">
  <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-3.5 flex items-center justify-between">
    <!-- Left: Logo & Wordmark -->
    <a href="/" class="flex items-center gap-2.5 group relative z-50">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-text transition-transform group-hover:scale-105 duration-200">
        <polyline points="16 18 22 12 16 6" />
        <polyline points="8 6 2 12 8 18" />
      </svg>
      <span class="font-mono text-sm font-bold tracking-tight lowercase text-text select-none">
        nimicode
      </span>
    </a>

    <!-- Center: Links (Desktop) -->
    <nav class="hidden md:flex items-center gap-7">
      {links.map((link) => (
        <a 
          href={link.href} 
          class="text-xs font-semibold text-text-muted hover:text-text transition-colors duration-200"
        >
          {link.name}
        </a>
      ))}
    </nav>

    <!-- Right: Star & Install Button (Desktop) -->
    <div class="hidden md:flex items-center gap-3">
      <!-- Github star-count pill -->
      <a 
        href="https://github.com/Harsh16gupta/Nimicode-web"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-border hover:bg-white/5 text-text-muted hover:text-text rounded-lg px-3 py-1.5 text-xs font-mono flex items-center gap-1.5 transition-colors duration-150"
      >
        <Star size={12} className="fill-current text-text-muted" />
        <span>Star</span>
        <span class="text-border">|</span>
        <span id="github-stars-desktop" class="font-semibold text-text">1,428</span>
      </a>

      <!-- Install button -->
      <a 
        href="#install" 
        class="bg-text hover:bg-text/90 text-bg rounded-lg px-4 py-1.5 text-xs font-semibold flex items-center gap-1.5 transition-all duration-150 active:scale-95"
      >
        <Terminal size={12} />
        <span>Install</span>
      </a>
    </div>

    <!-- Mobile Navigation Drawer Trigger -->
    <div class="md:hidden flex items-center">
      <MobileMenu client:load />
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('navbar');
  const handleScroll = () => {
    if (window.scrollY > 20) {
      nav?.classList.add('backdrop-blur-md', 'bg-bg/85', 'border-b', 'border-border', 'shadow-lg');
    } else {
      nav?.classList.remove('backdrop-blur-md', 'bg-bg/85', 'border-b', 'border-border', 'shadow-lg');
    }
  };
  window.addEventListener('scroll', handleScroll);
  handleScroll(); // Init script check on page mount
  
  // Dynamic github star fetching
  fetch('https://api.github.com/repos/Harsh16gupta/Nimicode-web')
    .then(res => {
      if (res.ok) return res.json();
      throw new Error('Network error');
    })
    .then(data => {
      if (data && data.stargazers_count) {
        const count = data.stargazers_count.toLocaleString();
        const starsEl = document.getElementById('github-stars-desktop');
        if (starsEl) starsEl.textContent = count;
      }
    })
    .catch(() => {
      // Fail silently, keep static count
    });
</script>
