---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Roadmap — Nimicode Agent Progress" description="Track the progress of the Nimicode autonomous agent, from core features to upcoming TUI changes, planned diff confirmations, and git tools.">
  <Navbar />
   <main class="relative min-h-screen bg-[#09090B] pt-20 pb-24 overflow-x-hidden">
    <div class="max-w-[1280px] mx-auto px-5 sm:px-8 pt-[clamp(48px,8vw,88px)]">
      
      <!-- Page Header -->
      <header class="animate-fade-up max-w-[800px]">
        <span class="text-[10px] font-mono text-text-muted tracking-widest uppercase font-bold block mb-3">
          Built in the open
        </span>
        <h1 class="font-heading font-bold text-text leading-[1.1] tracking-tight mb-5" style="font-size: clamp(2rem, 4.5vw, 3rem);">
          What's next for Nimicode.
        </h1>
        <p class="text-text-muted leading-relaxed max-w-[640px] text-xs">
          A terminal UI, more tools, and a smarter loop — tracked publicly, shipped incrementally.
        </p>
 
        <!-- Status Legend -->
        <div class="flex flex-wrap gap-4 mt-8 text-[10px] font-mono text-text-muted select-none">
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#16A34A] inline-block" />
            <span>shipped</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#F59E0B] inline-block" />
            <span>in progress</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-border inline-block" />
            <span>planned</span>
          </div>
        </div>
      </header>

      <!-- Roadmap Timeline -->
      <div class="mt-14 relative pl-[15px] sm:pl-10">
        <!-- Line -->
        <div class="absolute left-[20px] sm:left-[5px] top-2 bottom-2 w-px bg-border" />

        <div class="space-y-10">
          
          <!-- Item 1: Shipped - Core Loop -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 0ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-[#16A34A] ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">Core agent loop</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-accent-soft text-accent rounded-full px-2 py-0.5">
                  shipped
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                Think → act → repeat, up to 15 turns, with <code class="font-mono text-xs bg-white/5 px-1 py-0.5 rounded text-text">read_file</code> / <code class="font-mono text-xs bg-white/5 px-1 py-0.5 rounded text-text">write_file</code> / <code class="font-mono text-xs bg-white/5 px-1 py-0.5 rounded text-text">execute_command</code> tools.
              </p>
            </div>
          </div>

          <!-- Item 2: Shipped - DeepSeek -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 80ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-[#16A34A] ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">DeepSeek provider</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-accent-soft text-accent rounded-full px-2 py-0.5">
                  shipped
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                OpenAI-compatible client, local credential storage, provider login/logout/set commands.
              </p>
            </div>
          </div>

          <!-- Item 3: In Progress - TUI -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 160ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-[#F59E0B] ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">Terminal UI (TUI)</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-[#F59E0B]/10 text-[#D97706] rounded-full px-2 py-0.5">
                  in progress
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                A live split view: chat transcript, file tree, and diffs — replacing scrolling stdout.
              </p>

              <!-- Nested TUI Preview Mockup Card -->
              <div class="relative mt-4 group/tui overflow-hidden rounded-lg border border-terminal-border bg-terminal-bg p-3 shadow-md max-w-[600px]">
                <div class="absolute inset-0 bg-transparent z-10 flex flex-col items-center justify-center pointer-events-none transition-opacity duration-300 group-hover/tui:opacity-0 select-none">
                  <span class="bg-black/85 text-[10px] font-mono text-terminal-text rounded px-2.5 py-1 border border-terminal-border/40 tracking-wide font-semibold shadow-xl">
                    sneak peek — hover to preview
                  </span>
                </div>
                
                <!-- TUI Layout Mockup -->
                <div class="opacity-30 blur-[2.5px] transition-all duration-500 group-hover/tui:blur-0 group-hover/tui:opacity-100 flex flex-col h-40 select-none font-mono text-[9px] text-terminal-text">
                  <!-- Header chrome -->
                  <div class="flex items-center justify-between pb-2 border-b border-terminal-border/40 mb-2">
                    <div class="flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-[#FF5F57]" />
                      <span class="w-1.5 h-1.5 rounded-full bg-[#FEBC2E]" />
                      <span class="w-1.5 h-1.5 rounded-full bg-[#28C840]" />
                    </div>
                    <span class="text-[8px] text-terminal-text/30">nimicode - split-panel ui</span>
                    <div class="w-6" />
                  </div>
                  
                  <!-- Panels -->
                  <div class="flex flex-row flex-grow gap-2.5 overflow-hidden">
                    <!-- File tree pane (1/4 width) -->
                    <div class="w-1/4 border-r border-terminal-border/30 pr-1.5 text-terminal-text/50">
                      <div class="font-bold text-accent mb-1">▼ nimicode-app</div>
                      <div class="pl-2">▼ src/</div>
                      <div class="pl-4 text-terminal-text/80">└─ tools.ts</div>
                      <div class="pl-4">└─ main.ts</div>
                      <div class="pl-2 text-terminal-text/40">├─ package.json</div>
                      <div class="pl-2 text-terminal-text/40">└─ README.md</div>
                    </div>
                    
                    <!-- Chat transcript pane (1/2 width) -->
                    <div class="w-1/2 border-r border-terminal-border/30 px-1">
                      <div class="text-accent/60 font-semibold mb-1">nimicode &gt; refactoring tools.ts</div>
                      <div class="text-terminal-text/70 mb-1 leading-[1.3] truncate">✓ read_file: read 142 lines from tools.ts</div>
                      <div class="text-[#F59E0B] font-semibold animate-pulse mb-1">⠋ thinking: planning next edit...</div>
                      <div class="text-terminal-text/40 text-[8px] mt-4">Press [Esc] to cancel · [Tab] focus panel</div>
                    </div>
                    
                    <!-- Diff view pane (1/4 width) -->
                    <div class="w-1/4 pl-1 text-[8px]">
                      <div class="text-terminal-text/40 mb-1 font-bold">DIFF PREVIEW</div>
                      <div class="bg-red-950/40 text-red-400 px-1 my-0.5 line-through">- readFileSync(p, 'utf8')</div>
                      <div class="bg-green-950/40 text-green-400 px-1 my-0.5 font-bold">+ await fs.readFile(p, 'utf8')</div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>

          <!-- Item 4: Planned - Diff preview before write -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 240ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-text-muted/20 border-2 border-bg ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">Diff preview before write</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-white/5 text-text-muted rounded-full px-2 py-0.5">
                  planned
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                See a colored diff and confirm before Nimicode touches a file, or skip with <code class="font-mono text-xs bg-white/5 px-1 py-0.5 rounded text-text">--yolo</code>.
              </p>
            </div>
          </div>

          <!-- Item 5: Planned - Session resume -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 320ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-text-muted/20 border-2 border-bg ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">Session resume</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-white/5 text-text-muted rounded-full px-2 py-0.5">
                  planned
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                Continue a previous agent run instead of starting fresh every time.
              </p>
            </div>
          </div>

          <!-- Item 6: Planned - git-aware tooling -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 400ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-text-muted/20 border-2 border-bg ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">git-aware tooling</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-white/5 text-text-muted rounded-full px-2 py-0.5">
                  planned
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                First-class <code class="font-mono text-xs bg-white/5 px-1 py-0.5 rounded text-text">git_diff</code> and <code class="font-mono text-xs bg-white/5 px-1 py-0.5 rounded text-text">git_commit</code> tools with auto-generated commit messages.
              </p>
            </div>
          </div>

          <!-- Item 7: Planned - Additional providers -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 480ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-text-muted/20 border-2 border-bg ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">Additional providers</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-white/5 text-text-muted rounded-full px-2 py-0.5">
                  planned
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                Anthropic, OpenAI, Ollama (offline), and OpenRouter support.
              </p>
            </div>
          </div>

          <!-- Item 8: Planned - Plan mode -->
          <div class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out relative group" style="transition-delay: 560ms;">
            <!-- Status Dot -->
            <div class="absolute left-[-20px] sm:left-[-40px] top-6 w-[11px] h-[11px] rounded-full bg-text-muted/20 border-2 border-bg ring-4 ring-bg z-10" />
            
            <div class="bg-surface border border-border rounded-xl p-5 hover:border-text/15 transition-all duration-300 shadow-sm">
              <div class="flex items-center gap-2">
                <h4 class="font-mono font-semibold text-sm text-text">Plan mode</h4>
                <span class="text-[9px] uppercase tracking-wider font-bold bg-white/5 text-text-muted rounded-full px-2 py-0.5">
                  planned
                </span>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">
                Read-only dry run that outputs a file-by-file change plan for approval before writing anything.
              </p>
            </div>
          </div>

        </div>
      </div>

      <!-- Community CTA -->
      <section class="reveal-timeline-item opacity-0 translate-y-4 transition-all duration-700 ease-out mt-24 border-t border-border pt-16 text-center" style="transition-delay: 0ms;">
        <h2 class="font-heading text-2xl lg:text-3xl font-semibold text-text mb-3">
          Have an idea for a tool?
        </h2>
        <p class="text-text-muted text-sm max-w-[500px] mx-auto leading-relaxed">
          Nimicode is MIT-licensed and built in public — open an issue or ship a PR.
        </p>
        
        <div class="flex flex-wrap justify-center items-center gap-3 mt-8">
          <!-- Primary button -->
          <a
            href="https://github.com/Harsh16gupta/Nimicode-web/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-accent hover:bg-accent-hover text-white rounded-full px-6 py-3 text-sm font-semibold flex items-center gap-2 transition-all duration-200 shadow-sm shadow-accent/25 hover:scale-[1.02] active:scale-[0.98]"
          >
            <!-- Lucide MessageSquarePlus SVG inline -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square-plus"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v6"/><path d="M9 10h6"/></svg>
            <span>Open an Issue</span>
          </a>

          <!-- Secondary button -->
          <a
            href="https://github.com/Harsh16gupta/Nimicode-web/blob/main/CONTRIBUTING.md"
            target="_blank"
            rel="noopener noreferrer"
            class="border border-border hover:border-text/30 bg-transparent text-text rounded-full px-6 py-3 text-sm font-semibold flex items-center gap-2 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
          >
            <!-- Lucide BookOpen SVG inline -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            <span>View Contributing Guide</span>
          </a>
        </div>
      </section>

    </div>
  </main>
</Layout>

<script>
  // Simple CSS IntersectionObserver reveal for timeline items
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-4');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.05 });

  document.querySelectorAll('.reveal-timeline-item').forEach((el) => {
    observer.observe(el);
  });
</script>
