{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nimicode-web",
  "compatibility_date": "2026-07-21",
  "main": "dist/_worker.js/index.js",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
    "exclude": ["_worker.js/**", "_worker.js"]
  },
  "observability": {
    "enabled": true
  }
}
